{
    "version": 2,
    "builds": [
      {
        "src": "pages/api/verificar.js",
        "use": "@vercel/node"
      },
      {
        "src": "pages/index.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/",
        "dest": "/pages/index.js"
      },
      {
        "src": "/api/verificar",
        "dest": "/pages/api/verificar.js"
      }
    ]
  }
  